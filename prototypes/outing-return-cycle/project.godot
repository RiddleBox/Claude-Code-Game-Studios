[physics]

2d/physics_engine="default"
3d/physics_engine="jolt"

[rendering]

quality/driver/driver_name="GLES3"
quality/filters/use_nearest_mipmap_filter=false
quality/filters/anisotropic_filter_level=4
quality/filters/msaa=0
